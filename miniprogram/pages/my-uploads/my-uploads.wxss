@import "../my-favorites/my-favorites.wxss";

.page-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.add-btn { padding: 18rpx 28rpx; border: 0; border-radius: 999rpx; background: #f2fbf6; color: #178f5d; font-size: 25rpx; font-weight: 800; }
.upload-row-actions { display: flex; align-items: center; gap: 14rpx; }
.edit-btn { padding: 14rpx 22rpx; border-radius: 999rpx; background: #eaf7f0; color: #178f5d; font-size: 24rpx; font-weight: 800; }
.upload-mask{position:fixed;z-index:30;inset:0;display:flex;align-items:flex-end;background:rgba(0,0,0,.32)}.upload-sheet{width:100%;max-height:88vh;padding:28rpx 28rpx calc(34rpx + env(safe-area-inset-bottom));overflow-y:auto;border-radius:32rpx 32rpx 0 0;background:#fff;box-sizing:border-box}.form-head{display:flex;align-items:center;justify-content:space-between}.form-title{font-size:34rpx;font-weight:800}.form-close{color:#81786d;font-size:52rpx}.field{margin-top:22rpx}.field-label{display:block;margin-bottom:10rpx;color:#6f6860;font-size:24rpx}.place-search-field{display:flex;align-items:center;height:78rpx;overflow:hidden;border:1rpx solid #dadce0;border-radius:18rpx;background:#fff}.place-search-input{flex:1;min-width:0;height:76rpx;padding:0 22rpx;font-size:27rpx}.place-locate-btn{flex:none;height:76rpx;padding:0 22rpx;border-left:1rpx solid #e5e7eb;color:#178f5d;font-size:24rpx;font-weight:800;line-height:76rpx}.selected-address,.suggestion-name,.suggestion-address{display:block}.selected-address{margin-top:8rpx;color:#81786d;font-size:22rpx}.suggestion-list{margin-top:10rpx;overflow:hidden;border:1rpx solid #e5e7eb;border-radius:16rpx}.suggestion-item{padding:17rpx 20rpx;border-bottom:1rpx solid #e5e7eb}.suggestion-item:last-child{border-bottom:0}.suggestion-name{font-size:26rpx;font-weight:800}.suggestion-address{margin-top:5rpx;color:#81786d;font-size:22rpx}.picker-shell{display:flex;align-items:center;width:100%;min-height:78rpx;padding:0 22rpx;border:1rpx solid #dadce0;border-radius:18rpx;background:#fff;box-sizing:border-box;font-size:27rpx}.textarea{width:100%;min-height:150rpx;padding:18rpx 22rpx;border:1rpx solid #dadce0;border-radius:18rpx;background:#fff;box-sizing:border-box;font-size:27rpx}.tag-group{margin-bottom:16rpx}.tag-group-title{display:block;margin-bottom:6rpx;color:#81786d;font-size:22rpx;font-weight:800}.tag-options{display:flex;flex-wrap:wrap}.form-save{display:flex;align-items:center;justify-content:center;height:82rpx;margin-top:26rpx;border-radius:20rpx;background:#f2fbf6;color:#178f5d;font-size:28rpx;font-weight:900}.form-save.disabled{opacity:.55}
