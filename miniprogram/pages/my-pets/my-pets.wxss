.pets-page{padding-bottom:60rpx}.page-head{display:flex;align-items:center;justify-content:space-between;margin:8rpx 4rpx 28rpx}.page-title,.page-copy{display:block}.page-title{font-size:44rpx;font-weight:800}.page-copy{margin-top:8rpx;color:#81786d;font-size:24rpx}.add-btn{padding:18rpx 24rpx;border-radius:999rpx;background:#178f5d;color:#fff;font-weight:800}.pet-card{display:flex;align-items:center;gap:20rpx;margin-bottom:18rpx;padding:22rpx;border-radius:28rpx;background:#fff;box-shadow:0 12rpx 32rpx rgba(20,20,20,.05)}.pet-avatar{width:108rpx;height:108rpx;border-radius:30rpx;background:#eee}.fallback{color:#fff;background:#efb13d;text-align:center;font-size:34rpx;font-weight:800;line-height:108rpx}.pet-info{flex:1}.pet-name,.pet-meta,.pet-extra{display:block}.pet-name{font-size:32rpx;font-weight:800}.pet-meta{margin-top:8rpx;color:#5f584f;font-size:25rpx}.pet-extra{margin-top:6rpx;color:#9a9186;font-size:21rpx}.remove{color:#c24b45;font-size:23rpx}.empty{margin-top:150rpx;color:#9a9186;text-align:center}.form-mask{position:fixed;z-index:30;inset:0;display:flex;align-items:flex-end;background:rgba(0,0,0,.38)}.pet-form{width:100%;max-height:92vh;padding:30rpx 28rpx calc(30rpx + env(safe-area-inset-bottom));overflow-y:auto;border-radius:36rpx 36rpx 0 0;background:#ffffff;box-sizing:border-box}.form-title-row{display:flex;justify-content:space-between}.form-title{font-size:38rpx;font-weight:800}.close{font-size:48rpx;color:#81786d}.species-tabs{display:grid;grid-template-columns:repeat(3,1fr);gap:16rpx;margin:26rpx 0}.species-tab{display:flex;align-items:center;justify-content:center;gap:10rpx;height:96rpx;border-radius:24rpx;background:#fff;color:#5f584f;font-weight:800}.species-tab.active{background:#ffb718;color:#fff}.species-icon{font-size:31rpx}.form-fields{padding:0 22rpx;border-radius:28rpx;background:#fff}.field-row{display:flex;align-items:center;justify-content:space-between;min-height:90rpx;border-bottom:1rpx solid #eee;font-size:28rpx}.field-row:last-child{border-bottom:0}.field-row input{width:360rpx;text-align:right}.value{color:#9a9186}.form-avatar,.avatar-picker{width:66rpx;height:66rpx;border-radius:20rpx}.avatar-picker{background:#eee;color:#777;text-align:center;font-size:35rpx;line-height:66rpx}.choice{display:flex;gap:12rpx}.choice-btn{padding:12rpx 28rpx;border:1rpx solid #ddd;border-radius:12rpx;color:#777}.choice-btn.active{border-color:#178f5d;background:#eaf7f0;color:#178f5d}.save-btn{height:84rpx;margin-top:28rpx;border-radius:999rpx;background:#ffb718;text-align:center;font-size:30rpx;font-weight:800;line-height:84rpx}
.add-btn,.save-btn{border:0;background:#fff5df;color:#a66b00}.species-tab.active{border:0;background:#fff5df;color:#a66b00}.choice-btn,.choice-btn.active{border:0}.choice-btn.active{background:#eaf7f0;color:#178f5d}
