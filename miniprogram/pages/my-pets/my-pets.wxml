<view class="page pets-page">
  <view class="page-head"><view><text class="page-title">我的宠物</text><text class="page-copy">记录陪伴你的每一位家人</text></view><view class="add-btn" bindtap="openAdd">＋ 新增</view></view>
  <view wx:if="{{pets.length}}" class="pet-list"><view wx:for="{{pets}}" wx:key="id" class="pet-card"><image wx:if="{{item.avatarSrc}}" class="pet-avatar" src="{{item.avatarSrc}}" mode="aspectFill"/><view wx:else class="pet-avatar fallback">宠</view><view class="pet-info"><text class="pet-name">{{item.name}}</text><text class="pet-meta">{{item.breedName}} · {{item.genderName}}</text><text class="pet-extra">{{item.neutered ? '已绝育' : '未绝育'}}{{item.birthDate ? ' · '+item.birthDate : ''}}</text></view><view class="remove" data-id="{{item.id}}" catchtap="remove">删除</view></view></view>
  <view wx:else class="empty">还没有宠物，点击右上角新增吧。</view>
  <view wx:if="{{showForm}}" class="form-mask" bindtap="closeForm"><view class="pet-form" catchtap="noop"><view class="form-title-row"><text class="form-title">完善宠物信息</text><text class="close" bindtap="closeForm">×</text></view><view class="species-tabs"><view wx:for="{{speciesOptions}}" wx:key="code" class="species-tab {{form.species===item.code?'active':''}}" data-code="{{item.code}}" bindtap="selectSpecies"><text class="species-icon">{{item.icon}}</text><text>{{item.label}}</text></view></view><view class="form-fields"><view class="field-row"><text>宠物姓名</text><input value="{{form.name}}" placeholder="点击输入" bindinput="onName"/></view><view class="field-row"><text>宠物头像</text><view bindtap="chooseAvatar"><image wx:if="{{avatarPath}}" class="form-avatar" src="{{avatarPath}}" mode="aspectFill"/><view wx:else class="avatar-picker">＋</view></view></view><picker range="{{breeds}}" range-key="label" bindchange="onBreed"><view class="field-row"><text>品种</text><text class="value">{{breedIndex>=0?breeds[breedIndex].label:'请选择'}} ›</text></view></picker><picker mode="date" end="2026-07-22" bindchange="onBirth"><view class="field-row"><text>出生日期</text><text class="value">{{form.birthDate||'选择日期'}} ›</text></view></picker><picker range="{{genders}}" range-key="label" bindchange="onGender"><view class="field-row"><text>宠物性别</text><text class="value">{{genderIndex>=0?genders[genderIndex].label:'请选择'}} ›</text></view></picker><view class="field-row"><text>是否绝育</text><view class="choice"><text class="choice-btn {{!form.neutered?'active':''}}" data-value="false" bindtap="onNeutered">否</text><text class="choice-btn {{form.neutered?'active':''}}" data-value="true" bindtap="onNeutered">是</text></view></view></view><view class="save-btn" bindtap="save">保存</view></view></view>
</view>
