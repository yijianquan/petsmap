.groups-page{padding-bottom:150rpx}.place-head{margin:8rpx 0 24rpx;padding:28rpx;border-radius:26rpx;background:linear-gradient(135deg,#eaf7f0,#fff)}.head-label,.head-name{display:block}.head-label{color:#178f5d;font-size:23rpx;font-weight:800}.head-name{margin-top:8rpx;font-size:34rpx;font-weight:800}.group-row{display:flex;align-items:center;gap:20rpx;margin-bottom:16rpx;padding:26rpx;border-radius:24rpx;background:#fff}.group-main{flex:1}.group-name,.group-meta{display:block}.group-name{font-size:29rpx;font-weight:800}.group-meta{margin-top:10rpx;color:#8a8177;font-size:23rpx}.join-btn{padding:16rpx 27rpx;border-radius:999rpx;background:#178f5d;color:#fff;font-size:24rpx;font-weight:800}.join-btn.joined{background:#eaf7f0;color:#178f5d}.empty{padding:80rpx 20rpx;color:#81786d;text-align:center}.create-bar{position:fixed;right:0;bottom:0;left:0;padding:18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));background:#fff}.create-btn,.confirm-btn{padding:24rpx;border-radius:24rpx;background:#178f5d;color:#fff;text-align:center;font-weight:800}.sheet-mask{position:fixed;z-index:20;inset:0;display:flex;align-items:flex-end;background:rgba(0,0,0,.35)}.sheet{width:100%;padding:34rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));border-radius:36rpx 36rpx 0 0;background:#fff}.sheet-title{display:block;font-size:34rpx;font-weight:800}.name-input{height:92rpx;margin:26rpx 0;padding:0 24rpx;border-radius:22rpx;background:#f5f1ea;font-size:28rpx}
.join-btn,.create-btn,.confirm-btn{border:0;background:#f2fbf6;color:#178f5d}.join-btn.joined{background:#fff}
