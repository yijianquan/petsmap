<view class="page groups-page">
  <view class="place-head"><text class="head-label">地点</text><text class="head-name">{{placeName}}</text></view>
  <view wx:for="{{groups}}" wx:key="id" class="group-row" data-index="{{index}}" bindtap="handleGroup">
    <view class="group-main"><text class="group-name">{{item.name}}</text><text class="group-meta">{{item.memberCount}} 人 · 群主 {{item.ownerName}}</text></view>
  </view>
  <view wx:if="{{groups.length === 0}}" class="empty">暂无群聊</view>
  <view class="create-bar"><view class="create-btn" bindtap="openCreate">创建群聊</view></view>
  <view wx:if="{{showCreate}}" class="sheet-mask" bindtap="closeCreate">
    <view class="sheet" catchtap="noop">
      <text class="sheet-title">创建群聊</text>
      <input class="name-input" value="{{groupName}}" maxlength="40" placeholder="输入群聊名称" bindinput="onName" />
      <view class="confirm-btn" bindtap="createGroup">确定创建</view>
    </view>
  </view>
</view>
