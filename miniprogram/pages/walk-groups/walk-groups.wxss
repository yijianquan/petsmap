.walk-page{min-height:100vh}.walk-topbar{display:flex;gap:16rpx;align-items:center;margin:8rpx 0 22rpx}.city-pill{display:flex;align-items:center;flex:none;height:76rpx;max-width:190rpx;padding:0 22rpx;border:1rpx solid #dadce0;border-radius:20rpx;background:#fff;box-shadow:0 2rpx 8rpx rgba(60,64,67,.08);box-sizing:border-box;font-weight:800;white-space:nowrap}.down{color:#8a8177}.search-shell{display:flex;align-items:center;flex:1;height:76rpx;padding-left:22rpx;border:1rpx solid #dadce0;border-radius:20rpx;background:#fff;box-shadow:0 2rpx 8rpx rgba(60,64,67,.08);box-sizing:border-box}.search-shell input{flex:1;height:74rpx;font-size:25rpx}.search-btn{padding:18rpx 22rpx;color:#178f5d;font-size:24rpx;font-weight:800}.intro-card{display:block;margin-bottom:22rpx;padding:12rpx;border-radius:28rpx;background:linear-gradient(135deg,#eaf7f0,#fff);box-shadow:0 12rpx 34rpx rgba(23,143,93,.08)}.intro-title,.intro-copy{display:block}.intro-title{font-size:31rpx;font-weight:800}.intro-copy{margin-top:10rpx;color:#6f6860;font-size:24rpx;line-height:1.55}.group-card{display:flex;align-items:center;gap:20rpx;margin-bottom:18rpx;padding:28rpx;border-radius:26rpx;background:#fff;box-shadow:0 14rpx 40rpx rgba(20,20,20,.055)}.group-main{flex:1;min-width:0}.group-name,.place-name,.member-count{display:block}.group-name{font-size:31rpx;font-weight:800}.place-name{margin-top:8rpx;color:#635d56;font-size:25rpx}.member-count{margin-top:10rpx;color:#9a9186;font-size:23rpx}.join-btn{padding:17rpx 27rpx;border:0;border-radius:999rpx;background:#f2fbf6;color:#178f5d;font-size:24rpx;font-weight:800}.join-btn.joined{background:#fff;color:#178f5d}.empty{padding:90rpx 24rpx;color:#81786d;text-align:center;font-size:26rpx;line-height:1.7}.empty text{display:block}
.group-title-row,.group-place-row{display:flex;align-items:center;justify-content:space-between;gap:18rpx}.group-title-row .member-count{flex:none;margin-top:0;color:#81786d}.group-place-row{margin-top:10rpx}.group-place-row .place-name{min-width:0;margin-top:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.group-distance{flex:none;color:#178f5d;font-size:23rpx;font-weight:800}
.group-title-row{justify-content:flex-start}
.walk-tools{display:grid;grid-template-columns:repeat(4,1fr);margin-bottom:24rpx;padding-bottom:24rpx;border-bottom:1rpx solid #e5e7eb}.walk-tool{display:flex;flex-direction:column;align-items:center;gap:10rpx;color:#5f584f;font-size:22rpx;font-weight:700}.face-tool-icon{display:grid;grid-template-columns:repeat(2,14rpx);grid-template-rows:repeat(2,14rpx);gap:7rpx;align-content:center;justify-content:center;width:72rpx;height:72rpx;border-radius:24rpx;background:#edf7f2}.face-dot{width:14rpx;height:14rpx;border-radius:50%;background:#178f5d}
