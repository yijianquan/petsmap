.detail-page {
  padding-bottom: 54rpx;
}

.detail-head {
  margin-top: 8rpx;
  border-top: 8rpx solid #178f5d;
}

.type-pill {
  display: inline-flex;
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #eaf7f0;
  color: #178f5d;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 46rpx;
}

.place-name {
  display: block;
  margin-top: 18rpx;
  color: #111111;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.place-address {
  display: block;
  margin-top: 12rpx;
  color: #6f6860;
  font-size: 26rpx;
  line-height: 1.45;
}

.score-row {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 18rpx;
  font-size: 24rpx;
}

.rating {
  color: #9b6a12;
}

.tag-line {
  margin-top: 14rpx;
}

.mini-tag {
  display: inline-flex;
  align-items: center;
  height: 46rpx;
  padding: 0 18rpx;
  margin: 8rpx 8rpx 0 0;
  border-radius: 999rpx;
  background: #edf7f2;
  color: #15784f;
  font-size: 23rpx;
  font-weight: 700;
}

.tag-empty {
  display: block;
  margin-top: 14rpx;
  color: #9a9186;
  font-size: 24rpx;
}

.info-card {
  margin-top: 18rpx;
}

.section-title {
  display: block;
  color: #111111;
  font-size: 31rpx;
  font-weight: 800;
}

.body-text {
  display: block;
  margin-top: 14rpx;
  color: #3a352f;
  font-size: 26rpx;
  line-height: 1.6;
}

.note {
  color: #81786d;
}

.small-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 116rpx;
  height: 54rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #178f5d;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 54rpx;
  box-shadow: 0 12rpx 28rpx rgba(23, 143, 93, 0.18);
}

.small-btn:active,
.detail-upload-btn:active {
  opacity: 0.78;
}

.comment-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(20, 20, 20, 0.08);
}

.comment-user {
  font-size: 27rpx;
  font-weight: 700;
}

.comment-image {
  width: 180rpx;
  height: 140rpx;
  margin-top: 14rpx;
  border-radius: 18rpx;
}

.comment-time {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(0, 0, 0, 0.34);
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  max-height: 86vh;
  overflow-y: auto;
  padding: 28rpx 28rpx 44rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
}

.close {
  font-size: 52rpx;
  color: #81786d;
}

.save-btn {
  margin-top: 24rpx;
}

.detail-upload-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 22rpx;
  border-color: rgba(23, 143, 93, 0.18);
  background: #f2fbf6;
  color: #15784f;
  font-weight: 800;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #178f5d;
  box-shadow: 0 14rpx 32rpx rgba(23, 143, 93, 0.18);
}
