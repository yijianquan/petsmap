.chat-page{height:100vh;background:#f7f7f7}.chat-head{display:flex;align-items:center;justify-content:space-between;padding:18rpx 26rpx;border-bottom:1rpx solid #ededed;background:#fff}.chat-name,.chat-meta{display:block}.chat-name{font-size:31rpx;font-weight:800}.chat-meta{margin-top:6rpx;color:#8a8177;font-size:22rpx}.head-actions{display:flex;gap:12rpx}.members-btn,.manage-btn{padding:13rpx 18rpx;border-radius:999rpx;background:#eaf7f0;color:#178f5d;font-size:22rpx;font-weight:800}.message-list{height:calc(100vh - 206rpx)}.message-row{display:flex;align-items:flex-start;gap:16rpx;padding:18rpx 24rpx 8rpx}.message-row.mine{flex-direction:row-reverse}.avatar{flex:none;width:72rpx;height:72rpx;border-radius:10rpx;background:#ddd}.message-body{display:flex;flex-direction:column;align-items:flex-start;min-width:0;max-width:74%}.message-row.mine .message-body{align-items:flex-end}.sender,.time{display:block;color:#a0a0a8;font-size:20rpx}.message-row.mine .sender,.message-row.mine .time{text-align:right}.bubble{display:inline-block;width:auto;max-width:100%;box-sizing:border-box;margin:7rpx 0 4rpx;padding:15rpx 20rpx;border-radius:10rpx;background:#eeeeef;color:#202124;font-size:27rpx;line-height:1.5;word-break:break-all}.mine .bubble{border-radius:10rpx;background:#d9f3df}.message-bottom{height:30rpx}.composer{position:fixed;right:0;bottom:0;left:0;display:flex;gap:16rpx;padding:16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));border-top:1rpx solid #ededed;background:#fff}.composer input{flex:1;height:74rpx;padding:0 22rpx;border:1rpx solid #dadce0;border-radius:12rpx;background:#fff;box-sizing:border-box}.send-btn{display:flex;align-items:center;padding:0 24rpx;border-radius:12rpx;background:#178f5d;color:#fff;font-weight:800}.sheet-mask{position:fixed;z-index:10;inset:0;display:flex;align-items:flex-end;background:rgba(0,0,0,.35)}.sheet{width:100%;padding:34rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));border-radius:36rpx 36rpx 0 0;background:#fff}.sheet-title{display:block;font-size:34rpx;font-weight:800}.name-input{height:90rpx;margin:24rpx 0;padding:0 22rpx;border-radius:22rpx;background:#f7f7f7}.save-btn,.danger-btn{padding:23rpx;border-radius:22rpx;text-align:center;font-weight:800}.save-btn{background:#178f5d;color:#fff}.danger-btn{margin-top:18rpx;background:#fff0f0;color:#d64545}.member-mask{position:fixed;z-index:12;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.36)}.member-card{display:flex;flex-direction:column;align-items:center;width:500rpx;max-height:78vh;padding:46rpx 34rpx;overflow-y:auto;border-radius:34rpx;background:#fff}.profile-avatar{width:150rpx;height:150rpx;border-radius:48rpx;background:#ddd}.profile-name{margin:22rpx 0 14rpx;font-size:34rpx;font-weight:800}.owner-tag{padding:9rpx 16rpx;border-radius:999rpx;background:#fff1d6;color:#a66b00;font-size:21rpx;font-weight:800}.profile-tip{margin-top:24rpx;color:#9a9186;font-size:22rpx}.profile-pets{width:100%;margin-top:26rpx;padding-top:8rpx;border-top:1rpx solid #f0ece6}.profile-pet{display:flex;align-items:center;gap:16rpx;padding:14rpx 4rpx}.pet-avatar{width:76rpx;height:76rpx;border-radius:22rpx;background:#eee}.pet-fallback{color:#fff;background:#efb13d;text-align:center;font-weight:800;line-height:76rpx}.pet-data{flex:1}.pet-name,.pet-detail{display:block}.pet-name{font-size:27rpx;font-weight:800}.pet-detail{margin-top:5rpx;color:#81786d;font-size:22rpx}
.members-btn,.manage-btn{border:0;background:#f2fbf6;color:#178f5d}.mine .bubble{background:#edf7f2}.send-btn,.save-btn{border:0;background:#f2fbf6;color:#178f5d}
.join-chat-btn{padding:13rpx 24rpx;border-radius:999rpx;background:#edf7f2;color:#178f5d;font-size:23rpx;font-weight:900}.send-btn.disabled{background:#f1eee8;color:#aaa29a}
.chat-head>view:first-child{min-width:0;flex:1;margin-right:18rpx}.chat-title-row,.chat-place-row{display:flex;align-items:center;gap:12rpx}.chat-name{min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.chat-count,.chat-distance{flex:none;color:#178f5d;font-size:22rpx;font-weight:800}.chat-place-row{margin-top:6rpx}.chat-place-row .chat-meta{min-width:0;margin-top:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.manage-name-row{display:flex;align-items:center;margin:24rpx 0;border-radius:22rpx;background:#f8f6f2}.manage-name-row .name-input{flex:1;min-width:0;margin:0;background:transparent}.inline-save-btn{flex:none;padding:18rpx 24rpx;color:#178f5d;font-size:25rpx;font-weight:900}
