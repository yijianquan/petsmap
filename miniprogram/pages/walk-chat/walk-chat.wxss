.chat-page{height:100vh;background:#f5f1ea}.chat-head{display:flex;align-items:center;justify-content:space-between;padding:20rpx 26rpx;background:#fff}.chat-name,.chat-meta{display:block}.chat-name{font-size:31rpx;font-weight:800}.chat-meta{margin-top:6rpx;color:#8a8177;font-size:22rpx}.head-actions{display:flex;gap:12rpx}.members-btn,.manage-btn{padding:13rpx 18rpx;border-radius:999rpx;background:#eaf7f0;color:#178f5d;font-size:22rpx;font-weight:800}.message-list{height:calc(100vh - 210rpx)}.message-row{display:flex;gap:14rpx;padding:20rpx 24rpx}.message-row.mine{flex-direction:row-reverse}.avatar{width:68rpx;height:68rpx;border-radius:22rpx;background:#ddd}.message-body{max-width:72%}.sender,.time{display:block;color:#8a8177;font-size:20rpx}.message-row.mine .sender,.message-row.mine .time{text-align:right}.bubble{margin:7rpx 0;padding:18rpx 22rpx;border-radius:8rpx 24rpx 24rpx;background:#fff;font-size:27rpx;line-height:1.5;word-break:break-all}.mine .bubble{border-radius:24rpx 8rpx 24rpx 24rpx;background:#bcebd5}.message-bottom{height:30rpx}.composer{position:fixed;right:0;bottom:0;left:0;display:flex;gap:16rpx;padding:16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));background:#fff}.composer input{flex:1;height:74rpx;padding:0 22rpx;border-radius:22rpx;background:#f5f1ea}.send-btn{display:flex;align-items:center;padding:0 24rpx;border-radius:22rpx;background:#178f5d;color:#fff;font-weight:800}.sheet-mask{position:fixed;z-index:10;inset:0;display:flex;align-items:flex-end;background:rgba(0,0,0,.35)}.sheet{width:100%;padding:34rpx 30rpx calc(34rpx + env(safe-area-inset-bottom));border-radius:36rpx 36rpx 0 0;background:#fff}.sheet-title{display:block;font-size:34rpx;font-weight:800}.name-input{height:90rpx;margin:24rpx 0;padding:0 22rpx;border-radius:22rpx;background:#f5f1ea}.save-btn,.danger-btn{padding:23rpx;border-radius:22rpx;text-align:center;font-weight:800}.save-btn{background:#178f5d;color:#fff}.danger-btn{margin-top:18rpx;background:#fff0f0;color:#d64545}.member-mask{position:fixed;z-index:12;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.36)}.member-card{display:flex;flex-direction:column;align-items:center;width:500rpx;padding:46rpx 34rpx;border-radius:34rpx;background:#fff}.profile-avatar{width:150rpx;height:150rpx;border-radius:48rpx;background:#ddd}.profile-name{margin:22rpx 0 14rpx;font-size:34rpx;font-weight:800}.owner-tag{padding:9rpx 16rpx;border-radius:999rpx;background:#fff1d6;color:#a66b00;font-size:21rpx;font-weight:800}.profile-tip{margin-top:24rpx;color:#9a9186;font-size:22rpx}
