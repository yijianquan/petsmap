<view class="chat-page">
  <view class="chat-head">
    <view bindtap="openMembers">
      <view class="chat-place-row"><text class="chat-meta">{{group.placeName}}</text><text wx:if="{{distanceText}}" class="chat-distance">{{distanceText}}</text></view>
    </view>
    <view class="head-actions">
      <view class="members-btn" bindtap="openMembers">群信息</view>
      <view wx:if="{{group.owner}}" class="manage-btn" bindtap="openManage">管理</view>
      <view wx:elif="{{!group.joined}}" class="join-chat-btn" bindtap="join">加入</view>
    </view>
  </view>
  <scroll-view scroll-y class="message-list" scroll-into-view="{{scrollIntoView}}">
    <view wx:for="{{messages}}" wx:key="id" id="message-{{item.id}}" class="message-row {{item.mine ? 'mine' : ''}}">
      <image class="avatar" src="{{item.avatarSrc}}" mode="aspectFill" data-index="{{index}}" bindtap="showSender" />
      <view class="message-body"><text class="sender">{{item.senderName}}</text><view class="bubble">{{item.content}}</view><text class="time">{{item.createdAt}}</text></view>
    </view>
    <view class="message-bottom"></view>
  </scroll-view>
  <view class="composer"><input value="{{content}}" disabled="{{!group.joined}}" maxlength="500" placeholder="{{group.joined ? '说点什么...' : '加入群聊后可以发消息'}}" bindinput="onContent" confirm-type="send" bindconfirm="send" /><view class="send-btn {{!group.joined ? 'disabled' : ''}}" bindtap="send">发送</view></view>
  <view wx:if="{{showManage}}" class="sheet-mask" bindtap="closeManage">
    <view class="sheet" catchtap="noop">
      <text class="sheet-title">群聊管理</text>
      <input class="name-input" value="{{renameValue}}" maxlength="40" bindinput="onRename"/>
      <view class="save-btn" bindtap="rename">保存群名</view>
      <view class="danger-btn" style="padding:14rpx 20rpx;border-radius:18rpx;font-size:24rpx;" bindtap="dissolve">解散群聊</view>
    </view>
  </view>
  <view wx:if="{{selectedMember}}" class="member-mask" bindtap="closeMember">
    <view class="member-card" catchtap="noop">
      <image class="profile-avatar" src="{{selectedMember.avatarSrc}}" mode="aspectFill"/>
      <text class="profile-name">{{selectedMember.nickname}}</text>
      <text wx:if="{{selectedMember.owner}}" class="owner-tag">群主</text>
      <view wx:if="{{selectedMember.pets.length}}" class="profile-pets"><view wx:for="{{selectedMember.pets}}" wx:key="id" class="profile-pet"><image wx:if="{{item.avatarSrc}}" class="pet-avatar" src="{{item.avatarSrc}}" mode="aspectFill"/><view wx:else class="pet-avatar pet-fallback">宠</view><view class="pet-data"><text class="pet-name">{{item.name}}</text><text class="pet-detail">{{item.genderName}} · {{item.breedName}}</text></view></view></view><text wx:else class="profile-tip">暂未添加宠物</text>
    </view>
  </view>
</view>
