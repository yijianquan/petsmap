.member-head{margin:8rpx 0 22rpx}.title,.count{display:block}.title{font-size:38rpx;font-weight:800}.count{margin-top:8rpx;color:#81786d;font-size:24rpx}.member-row{display:flex;align-items:center;gap:18rpx;margin-bottom:14rpx;padding:22rpx;border-radius:24rpx;background:#fff}.avatar{width:76rpx;height:76rpx;border-radius:24rpx;background:#ddd}.nickname{flex:1;font-size:28rpx;font-weight:700}.owner-tag{padding:9rpx 16rpx;border-radius:999rpx;background:#fff1d6;color:#a66b00;font-size:21rpx;font-weight:800}
.page{padding-bottom:150rpx}.invite-bar{position:fixed;z-index:8;right:0;bottom:0;left:0;padding:18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));background:#fff;box-shadow:0 -10rpx 32rpx rgba(20,20,20,.08)}.invite-btn{height:82rpx;border:0;border-radius:24rpx;background:#178f5d;color:#fff;font-size:28rpx;font-weight:800;line-height:82rpx}.invite-btn::after{border:0}
.member-mask{position:fixed;z-index:10;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.36)}.member-card{display:flex;flex-direction:column;align-items:center;width:500rpx;padding:46rpx 34rpx;border-radius:34rpx;background:#fff}.profile-avatar{width:150rpx;height:150rpx;border-radius:48rpx;background:#ddd}.profile-name{margin:22rpx 0 14rpx;font-size:34rpx;font-weight:800}.profile-tip{margin-top:24rpx;color:#9a9186;font-size:22rpx}
