.member-head{margin:8rpx 0 22rpx}.title,.count{display:block}.title{font-size:38rpx;font-weight:800}.count{margin-top:8rpx;color:#81786d;font-size:24rpx}.member-row{display:flex;align-items:center;gap:18rpx;margin-bottom:14rpx;padding:22rpx;border-radius:24rpx;background:#fff}.avatar{width:76rpx;height:76rpx;border-radius:24rpx;background:#ddd}.nickname{flex:1;font-size:28rpx;font-weight:700}.owner-tag{padding:9rpx 16rpx;border-radius:999rpx;background:#fff1d6;color:#a66b00;font-size:21rpx;font-weight:800}
.page{padding-bottom:150rpx}.invite-bar{position:fixed;z-index:8;right:0;bottom:0;left:0;padding:18rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));background:#fff;box-shadow:0 -10rpx 32rpx rgba(20,20,20,.08)}.invite-btn{height:82rpx;border:0;border-radius:24rpx;background:#f2fbf6;color:#178f5d;font-size:28rpx;font-weight:800;line-height:82rpx}.invite-btn::after{border:0}
.member-mask{position:fixed;z-index:10;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.36)}.member-card{display:flex;flex-direction:column;align-items:center;width:500rpx;padding:46rpx 34rpx;border-radius:34rpx;background:#fff}.profile-avatar{width:150rpx;height:150rpx;border-radius:48rpx;background:#ddd}.profile-name{margin:22rpx 0 14rpx;font-size:34rpx;font-weight:800}.profile-tip{margin-top:24rpx;color:#9a9186;font-size:22rpx}
.profile-pets{width:100%;margin-top:26rpx;padding-top:8rpx;border-top:1rpx solid #f0ece6}.profile-pet{display:flex;align-items:center;gap:16rpx;padding:14rpx 4rpx}.pet-avatar{width:76rpx;height:76rpx;border-radius:22rpx;background:#eee}.pet-fallback{color:#fff;background:#efb13d;text-align:center;font-weight:800;line-height:76rpx}.pet-data{flex:1}.pet-name,.pet-detail{display:block}.pet-name{font-size:27rpx;font-weight:800}.pet-detail{margin-top:5rpx;color:#81786d;font-size:22rpx}
.invite-bar{display:flex;align-items:center;gap:16rpx}.invite-btn{display:flex;flex:1;align-items:center;justify-content:center;gap:10rpx;background:linear-gradient(135deg,#edf9f3,#f7fcf9);box-shadow:0 10rpx 26rpx rgba(23,143,93,.10)}.invite-icon{display:inline-flex;align-items:center;justify-content:center;width:38rpx;height:38rpx;border-radius:50%;background:#d9f2e5;color:#178f5d;font-size:27rpx;line-height:38rpx}.leave-btn{flex:0 0 190rpx;height:82rpx;border-radius:24rpx;background:#fff1f0;color:#b42318;text-align:center;font-size:26rpx;font-weight:800;line-height:82rpx}
