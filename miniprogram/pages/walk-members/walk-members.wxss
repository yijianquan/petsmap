.member-head{display:flex;align-items:center;justify-content:space-between;margin:8rpx 0 22rpx}.title,.count{display:block}.title{font-size:38rpx;font-weight:800}.count{margin-top:8rpx;color:#81786d;font-size:24rpx}.invite-plus{width:70rpx;height:70rpx;border:1rpx solid #dadce0;border-radius:18rpx;background:#fff;color:#178f5d;text-align:center;font-size:48rpx;font-weight:300;line-height:66rpx;box-shadow:0 2rpx 8rpx rgba(60,64,67,.10)}.invite-menu{position:absolute;z-index:30;top:126rpx;right:28rpx;width:240rpx;padding:8rpx 0;overflow:hidden;border:1rpx solid #dadce0;border-radius:18rpx;background:#fff;box-shadow:0 12rpx 34rpx rgba(60,64,67,.20);box-sizing:border-box}.invite-option{display:flex;align-items:center;justify-content:flex-start;width:100%;height:76rpx;margin:0;padding:0 26rpx;border:0;border-radius:0;background:#fff;color:#202124;font-size:25rpx;font-weight:600;line-height:76rpx;text-align:left;box-sizing:border-box}.invite-option::after{border:0}.member-row{display:flex;align-items:center;gap:18rpx;margin-bottom:14rpx;padding:22rpx;border-radius:24rpx;background:#fff}.avatar{width:76rpx;height:76rpx;border-radius:24rpx;background:#ddd}.nickname{flex:1;font-size:28rpx;font-weight:700}.owner-tag{padding:9rpx 16rpx;border-radius:999rpx;background:#fff1d6;color:#a66b00;font-size:21rpx;font-weight:800}
.page{position:relative;padding-bottom:48rpx}
.member-mask{position:fixed;z-index:10;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.36)}.member-card{display:flex;flex-direction:column;align-items:center;width:500rpx;padding:46rpx 34rpx;border-radius:34rpx;background:#fff}.profile-avatar{width:150rpx;height:150rpx;border-radius:48rpx;background:#ddd}.profile-name{margin:22rpx 0 14rpx;font-size:34rpx;font-weight:800}.profile-tip{margin-top:24rpx;color:#9a9186;font-size:22rpx}
.profile-pets{width:100%;margin-top:26rpx;padding-top:8rpx;border-top:1rpx solid #f0ece6}.profile-pet{display:flex;align-items:center;gap:16rpx;padding:14rpx 4rpx}.pet-avatar{width:76rpx;height:76rpx;border-radius:22rpx;background:#eee}.pet-fallback{color:#fff;background:#efb13d;text-align:center;font-weight:800;line-height:76rpx}.pet-data{flex:1}.pet-name,.pet-detail{display:block}.pet-name{font-size:27rpx;font-weight:800}.pet-detail{margin-top:5rpx;color:#81786d;font-size:22rpx}
.leave-btn{height:72rpx;border-radius:20rpx;background:#fff1f0;color:#b42318;text-align:center;font-size:25rpx;font-weight:800;line-height:72rpx}
.admin-tag{padding:9rpx 16rpx;border-radius:999rpx;background:#edf7f2;color:#178f5d;font-size:21rpx;font-weight:800}.role-action{color:#178f5d;font-size:21rpx}.leave-row{margin-top:70rpx}.leave-row .leave-btn{width:100%}.request-section{margin:30rpx 0}.request-title{margin-bottom:14rpx;font-size:28rpx;font-weight:900}.request-row{display:flex;align-items:center;gap:14rpx;margin-bottom:12rpx;padding:18rpx;border-radius:22rpx;background:#fff}.request-avatar{width:64rpx;height:64rpx;border-radius:20rpx;background:#eee}.request-main{flex:1}.request-main text{display:block;font-size:24rpx}.request-main text+text{margin-top:5rpx;color:#81786d;font-size:20rpx}.request-reject,.request-approve{padding:12rpx 16rpx;border-radius:16rpx;font-size:22rpx;font-weight:800}.request-reject{background:#fff1f0;color:#b42318}.request-approve{background:#edf7f2;color:#178f5d}
