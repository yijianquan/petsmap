<view class="page city-page">
  <view class="city-search">
    <text class="city-search-icon">⌕</text>
    <input value="{{cityKeyword}}" placeholder="输入城市名模糊搜索" bindinput="onCitySearch" />
  </view>
  <view class="city-list">
    <view wx:for="{{cityGroups}}" wx:key="letter" class="city-group">
      <text class="group-letter">{{item.letter}}</text>
      <view class="group-card">
        <view wx:for="{{item.cities}}" wx:for-item="city" wx:key="name" class="city-row {{currentCity === city.name ? 'active' : ''}}" data-city="{{city.name}}" bindtap="selectCity">
          <view>
            <text class="city-name">{{city.name}}</text>
            <text class="city-tip">{{city.tip}}</text>
          </view>
          <text wx:if="{{currentCity === city.name}}" class="selected-mark">✓</text>
        </view>
      </view>
    </view>
  </view>
</view>
