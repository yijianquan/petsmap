.groups-page{padding-bottom:60rpx}.section-head{display:flex;align-items:baseline;margin:10rpx 4rpx 0;padding:0 4rpx 18rpx;border-bottom:1rpx solid #e5e7eb}.section-title{font-size:25rpx;font-weight:700}.section-count{color:#81786d;font-size:22rpx}.joined-section{margin-top:42rpx}.group-row{display:flex;align-items:center;gap:18rpx;margin-bottom:0;padding:25rpx 8rpx;border-bottom:1rpx solid #e5e7eb;background:transparent}.group-row:last-of-type{border-bottom:0}.group-main{flex:1;min-width:0}.name-row{display:flex;align-items:center;gap:10rpx}.group-name{overflow:hidden;font-size:29rpx;font-weight:800;text-overflow:ellipsis;white-space:nowrap}.member-count{flex:none;color:#81786d;font-size:23rpx}.place-name{display:block;overflow:hidden;margin-top:9rpx;color:#81786d;font-size:23rpx;text-overflow:ellipsis;white-space:nowrap}.arrow{color:#b6ada2;font-size:42rpx}.empty{height:120rpx}
