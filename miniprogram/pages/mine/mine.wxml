<view class="page">
  <view class="profile-panel clickable" bindtap="handleProfileTap">
    <image wx:if="{{userAvatarSrc}}" class="avatar" src="{{userAvatarSrc}}" mode="aspectFill" />
    <view wx:else class="avatar default-avatar">宠</view>
    <view class="profile-info">
      <text class="username">{{loggedIn ? (user.nickname || user.username) : '登录/注册'}}</text>
      <text wx:if="{{!loggedIn}}" class="muted">登录后可上传地点、写评论</text>
    </view>
    <text class="arrow">›</text>
  </view>

  <view wx:if="{{loggedIn}}" class="account-section">
    <view class="feature-grid">
      <view class="feature-button" data-page="my-uploads" bindtap="openFeature">
        <text class="feature-icon">＋</text>
        <text>上传地点</text>
      </view>
      <view class="feature-button" data-page="my-favorites" bindtap="openFeature">
        <text class="feature-icon">★</text>
        <text>我的收藏</text>
      </view>
    </view>

    <view class="logout-btn" bindtap="logout">退出登录</view>
  </view>

  <view wx:if="{{showProfileEditor}}" class="sheet-mask" bindtap="closeProfileEditor">
    <view class="sheet" catchtap="noop">
      <view class="row between">
        <text class="sheet-title">编辑资料</text>
        <text class="close" bindtap="closeProfileEditor">×</text>
      </view>
      <button class="editor-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{profileAvatarSrc}}" class="editor-avatar" src="{{profileAvatarSrc}}" mode="aspectFill" />
        <view wx:else class="editor-avatar default-avatar">宠</view>
      </button>
      <view class="field">
        <text class="field-label">昵称</text>
        <input class="input profile-input" type="nickname" value="{{profileForm.nickname}}" placeholder="填写微信昵称" bindinput="onNicknameInput" />
      </view>
      <view class="primary-save" bindtap="saveProfile">保存资料</view>
    </view>
  </view>
</view>
