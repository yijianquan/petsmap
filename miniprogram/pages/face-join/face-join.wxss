.face-page{padding-top:60rpx}.face-hero{text-align:center}.face-title,.face-copy,.session-meta{display:block}.face-title{font-size:38rpx;font-weight:900}.face-copy{margin-top:14rpx;color:#81786d;font-size:24rpx}.digit-row{display:flex;justify-content:center;gap:18rpx;margin:52rpx 0 28rpx}.digit{width:92rpx;height:108rpx;border-radius:24rpx;background:#fff;color:#178f5d;font-size:54rpx;font-weight:900;line-height:108rpx;box-shadow:0 12rpx 34rpx rgba(20,20,20,.05)}.code-input{position:fixed;left:-200vw;top:-200vh;width:2rpx;height:2rpx;opacity:0}.session-meta{color:#6f6860;font-size:23rpx}.enter-btn,.open-btn{margin-top:38rpx;padding:24rpx;border-radius:24rpx;background:#edf7f2;color:#178f5d;text-align:center;font-size:29rpx;font-weight:900}.participant-card{margin-top:42rpx;padding:28rpx;border-radius:30rpx;background:#fff}.participant-head{display:flex;justify-content:space-between;font-size:27rpx;font-weight:900}.avatar-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24rpx 12rpx;margin-top:28rpx}.participant{text-align:center;color:#81786d;font-size:21rpx}.participant-avatar{display:block;width:82rpx;height:82rpx;margin:0 auto 10rpx;border-radius:26rpx;background:#eee}.open-btn{margin-top:28rpx}
