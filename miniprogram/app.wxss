page {
  min-height: 100%;
  background: #ffffff;
  color: #171717;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.hero {
  padding: 36rpx 4rpx 24rpx;
}

.eyebrow {
  color: #8a8177;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.title {
  display: block;
  margin-top: 12rpx;
  font-size: 48rpx;
  line-height: 1.15;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 14rpx;
  color: #6f6860;
  font-size: 27rpx;
  line-height: 1.6;
}

.card {
  background: rgba(255, 255, 255, 0.92);
  border: 0;
  border-radius: 22rpx;
  padding: 26rpx;
  box-shadow: 0 18rpx 50rpx rgba(20, 20, 20, 0.06);
}

.row {
  display: flex;
  align-items: center;
}

.between {
  justify-content: space-between;
}

.muted {
  color: #81786d;
}

.primary-btn,
.ghost-btn,
.danger-btn {
  height: 80rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 80rpx;
}

.primary-btn {
  background: #ffffff;
  color: #178f5d;
  border: 0;
  box-shadow: 0 10rpx 26rpx rgba(23, 143, 93, 0.10);
}

.ghost-btn {
  background: #ffffff;
  color: #111111;
  border: 0;
}

.danger-btn {
  background: #fff1f0;
  color: #b42318;
}

.input,
.textarea,
.picker-shell {
  width: 100%;
  min-height: 78rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid #dadce0;
  box-shadow: 0 1rpx 3rpx rgba(60, 64, 67, 0.08);
  box-sizing: border-box;
  font-size: 28rpx;
}

.textarea {
  min-height: 150rpx;
  padding-top: 20rpx;
}

.field {
  margin-top: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #6f6860;
  font-size: 24rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  margin: 8rpx 10rpx 0 0;
  border-radius: 999rpx;
  background: #f1eee8;
  color: #4c463f;
  font-size: 23rpx;
}

.pill.active {
  background: #edf7f2;
  color: #178f5d;
  box-shadow: inset 0 0 0 1rpx rgba(23, 143, 93, 0.24);
}

.empty {
  padding: 56rpx 24rpx;
  color: #81786d;
  text-align: center;
}

.fab {
  position: fixed;
  right: 32rpx;
  bottom: 132rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #178f5d;
  font-size: 56rpx;
  line-height: 112rpx;
  border: 0;
  box-shadow: 0 20rpx 46rpx rgba(23, 143, 93, 0.16);
}
